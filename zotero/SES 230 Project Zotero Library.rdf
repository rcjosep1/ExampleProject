    </bib:Article>
    <bib:Memo rdf:about="#item_116">
        <rdf:value>&lt;div data-citation-items=&quot;%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FVHUXVJTT%22%5D%2C%22itemData%22%3A%7B%22id%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FVHUXVJTT%22%2C%22type%22%3A%22article-journal%22%2C%22container-title%22%3A%22Elements%22%2C%22issue%22%3A%221%22%2C%22title%22%3A%22Elements.%20Impacts!%22%2C%22volume%22%3A%228%22%2C%22author%22%3A%5B%7B%22family%22%3A%22Jourdan%22%2C%22given%22%3A%22Fred%22%7D%5D%7D%7D%5D&quot; data-schema-version=&quot;9&quot;&gt;&lt;p&gt;impact melt bearing impactities &lt;/p&gt;

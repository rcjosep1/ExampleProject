        <dc:date>May 1999</dc:date>
        <z:citationKey>sumnerStratigraphyNothernDespositional1999</z:citationKey>
    </bib:Article>
    <bib:Memo rdf:about="#item_151">
        <rdf:value>&lt;div data-citation-items=&quot;%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FWVJVXVWH%22%5D%2C%22itemData%22%3A%7B%22id%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FWVJVXVWH%22%2C%22type%22%3A%22article-journal%22%2C%22title%22%3A%22Stratigraphy%22%2C%22author%22%3A%5B%7B%22family%22%3A%22Sumner%22%2C%22given%22%3A%22Christopher%22%7D%5D%2C%22issued%22%3A%7B%22date-parts%22%3A%5B%5B%221999%22%5D%5D%7D%7D%7D%5D&quot; data-schema-version=&quot;9&quot;&gt;&lt;p&gt;&lt;span class=&quot;highlight&quot; data-annotation=&quot;%7B%22attachmentURI%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FBWFRAGZJ%22%2C%22annotationKey%22%3A%229QHL5YTW%22%2C%22color%22%3A%22%23ffd400%22%2C%22pageLabel%22%3A%2255%22%2C%22position%22%3A%7B%22pageIndex%22%3A72%2C%22rects%22%3A%5B%5B138.2%2C390.345%2C557.7%2C404.869%5D%2C%5B100.8%2C362.745%2C557.162%2C377.269%5D%5D%7D%2C%22citationItem%22%3A%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FWVJVXVWH%22%5D%2C%22locator%22%3A%2255%22%7D%7D&quot;&gt;“Four types of diagenetic cement occur in the Coconino Sandstone. They include: syntaxial quartz overgrowths, chalcedony, calcite, and iron oxides.”&lt;/span&gt; &lt;span class=&quot;citation&quot; data-citation=&quot;%7B%22citationItems%22%3A%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FWVJVXVWH%22%5D%2C%22locator%22%3A%2255%22%7D%5D%2C%22properties%22%3A%7B%7D%7D&quot;&gt;(&lt;span class=&quot;citation-item&quot;&gt;Sumner, 1999, p. 55&lt;/span&gt;)&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;/p&gt;
&lt;p&gt;calcite cement- patchy to complete pore-filling in over half of the SS. controlled by the amount of pressure dissolution, intense suturing, more often associated w medium grains than w fine grains &lt;/p&gt;
&lt;p&gt;iron oxides- dust-rims and secondary stains &lt;/p&gt;
&lt;/div&gt;</rdf:value>

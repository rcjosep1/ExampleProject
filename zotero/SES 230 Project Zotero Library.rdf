    <bib:Memo rdf:about="#item_363">
        <rdf:value>&lt;div data-citation-items=&quot;%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22itemData%22%3A%7B%22id%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%2C%22type%22%3A%22article-journal%22%2C%22citation-key%22%3A%22kringGuidebookGeologyBarringer2017%22%2C%22language%22%3A%22en%22%2C%22source%22%3A%22Zotero%22%2C%22title%22%3A%22Guidebook%20to%20the%20Geology%20of%20Barringer%20Meteorite%20Crater%2C%20Arizona%20(a%20k%20a%20Meteor%20Crater).%20Second%20edition%22%2C%22volume%22%3A%222040%22%2C%22author%22%3A%5B%7B%22family%22%3A%22Kring%22%2C%22given%22%3A%22David%20A%22%7D%5D%2C%22issued%22%3A%7B%22date-parts%22%3A%5B%5B%222017%22%2C7%5D%5D%7D%7D%7D%5D&quot; data-schema-version=&quot;9&quot;&gt;&lt;p&gt;&lt;/p&gt;
&lt;p&gt; &lt;span class=&quot;citation&quot; data-citation=&quot;%7B%22citationItems%22%3A%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%22230%22%7D%5D%2C%22properties%22%3A%7B%7D%7D&quot;&gt;(&lt;span class=&quot;citation-item&quot;&gt;Kring, 2017, p. 230&lt;/span&gt;)&lt;/span&gt;&lt;/p&gt;
&lt;/div&gt;</rdf:value>
    </bib:Memo>
    <bib:Memo rdf:about="#item_197">
        <rdf:value>&lt;div data-citation-items=&quot;%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22itemData%22%3A%7B%22id%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%2C%22type%22%3A%22article-journal%22%2C%22language%22%3A%22en%22%2C%22source%22%3A%22Zotero%22%2C%22title%22%3A%22Guidebook%20to%20the%20Geology%20of%20Barringer%20Meteorite%20Crater%2C%20Arizona%20(a%20k%20a%20Meteor%20Crater).%20Second%20edition%22%2C%22author%22%3A%5B%7B%22family%22%3A%22Kring%22%2C%22given%22%3A%22David%20A%22%7D%5D%2C%22issued%22%3A%7B%22date-parts%22%3A%5B%5B%222017%22%2C7%5D%5D%7D%7D%7D%5D&quot; data-schema-version=&quot;9&quot;&gt;&lt;p&gt;&lt;span class=&quot;highlight&quot; data-annotation=&quot;%7B%22attachmentURI%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFFVSAPIC%22%2C%22annotationKey%22%3A%22LXYF3AFG%22%2C%22color%22%3A%22%235fb236%22%2C%22pageLabel%22%3A%2253%22%2C%22position%22%3A%7B%22pageIndex%22%3A63%2C%22rects%22%3A%5B%5B72%2C702.683%2C344.895%2C715.267%5D%5D%7D%2C%22citationItem%22%3A%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%2253%22%7D%7D&quot;&gt;“5. Shock Metamorphism and Impact Melting”&lt;/span&gt; &lt;span class=&quot;citation&quot; data-citation=&quot;%7B%22citationItems%22%3A%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%2253%22%7D%5D%2C%22properties%22%3A%7B%7D%7D&quot;&gt;(&lt;span class=&quot;citation-item&quot;&gt;Kring, 2017, p. 53&lt;/span&gt;)&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;rock flour- pulverized Coco SS, fragmented quartz far smaller than unaffected grains, 15-20% of ejecta is rock flour&lt;/p&gt;
&lt;p&gt;Surviving rock fragments of Coco &lt;/p&gt;
&lt;p&gt;-Variety A: lighty-moderatly shocked, greater density that unshock, distributed in rock flour, ranges from 1 in to 12 ft, far more abundant than B&lt;/p&gt;
&lt;p&gt;-Variety B: melted, vesicular, and float on water, may just turn to rock flour TBH&lt;/p&gt;
&lt;p&gt;most energy from impact is used collapsing pore space that few solid state transformations happen &lt;/p&gt;
&lt;/div&gt;</rdf:value>
    </bib:Memo>
    <bib:Memo rdf:about="#item_286">
        <rdf:value>&lt;div data-citation-items=&quot;%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22itemData%22%3A%7B%22id%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%2C%22type%22%3A%22article-journal%22%2C%22citation-key%22%3A%22kringGuidebookGeologyBarringer2017%22%2C%22language%22%3A%22en%22%2C%22source%22%3A%22Zotero%22%2C%22title%22%3A%22Guidebook%20to%20the%20Geology%20of%20Barringer%20Meteorite%20Crater%2C%20Arizona%20(a%20k%20a%20Meteor%20Crater).%20Second%20edition%22%2C%22author%22%3A%5B%7B%22family%22%3A%22Kring%22%2C%22given%22%3A%22David%20A%22%7D%5D%2C%22issued%22%3A%7B%22date-parts%22%3A%5B%5B%222017%22%2C7%5D%5D%7D%7D%7D%5D&quot; data-schema-version=&quot;9&quot;&gt;&lt;p&gt;&lt;span class=&quot;highlight&quot; data-annotation=&quot;%7B%22attachmentURI%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFFVSAPIC%22%2C%22annotationKey%22%3A%22JIKL3K3S%22%2C%22color%22%3A%22%23ff6666%22%2C%22pageLabel%22%3A%22103%22%2C%22position%22%3A%7B%22pageIndex%22%3A113%2C%22rects%22%3A%5B%5B405.574%2C532.201%2C503.995%2C541.898%5D%2C%5B72%2C519.24%2C537.601%2C528.937%5D%2C%5B72%2C506.279%2C95.769%2C515.976%5D%5D%7D%2C%22citationItem%22%3A%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%22103%22%7D%7D&quot;&gt;“A lot of the meteoritic material was oxidized. It is sometimes simply called oxidized iron, but large masses are also called shale balls.”&lt;/span&gt; &lt;span class=&quot;citation&quot; data-citation=&quot;%7B%22citationItems%22%3A%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%22103%22%7D%5D%2C%22properties%22%3A%7B%7D%7D&quot;&gt;(&lt;span class=&quot;citation-item&quot;&gt;Kring, 2017, p. 103&lt;/span&gt;)&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span class=&quot;highlight&quot; data-annotation=&quot;%7B%22attachmentURI%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFFVSAPIC%22%2C%22annotationKey%22%3A%22B7LYNW2Q%22%2C%22color%22%3A%22%235fb236%22%2C%22pageLabel%22%3A%2258%22%2C%22position%22%3A%7B%22pageIndex%22%3A68%2C%22rects%22%3A%5B%5B254.668%2C642.487%2C537.546%2C652.184%5D%2C%5B71.989%2C629.526%2C495.737%2C639.223%5D%2C%5B71.989%2C616.565%2C367.662%2C626.262%5D%5D%7D%2C%22citationItem%22%3A%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%2258%22%7D%7D&quot;&gt;“Ca,Mg-rich (9 to 20 wt%) silicate glasses and crystalline calcite globules within silicate glass have been reported in an area Shoemaker mapped as alluvium, but reinterpreted to be an ejected impact breccia (Osinski et al., 2015).”&lt;/span&gt; &lt;span class=&quot;citation&quot; data-citation=&quot;%7B%22citationItems%22%3A%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%2258%22%7D%5D%2C%22properties%22%3A%7B%7D%7D&quot;&gt;(&lt;span class=&quot;citation-item&quot;&gt;Kring, 2017, p. 58&lt;/span&gt;)&lt;/span&gt; (indicate kaibab melted) &lt;/p&gt;
&lt;p&gt;&lt;/p&gt;
&lt;/div&gt;</rdf:value>
    </bib:Memo>
    <bib:Memo rdf:about="#item_179">
        <rdf:value>&lt;div data-citation-items=&quot;%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22itemData%22%3A%7B%22id%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%2C%22type%22%3A%22article-journal%22%2C%22language%22%3A%22en%22%2C%22source%22%3A%22Zotero%22%2C%22title%22%3A%22Guidebook%20to%20the%20Geology%20of%20Barringer%20Meteorite%20Crater%2C%20Arizona%20(a%20k%20a%20Meteor%20Crater).%20Second%20edition%22%2C%22author%22%3A%5B%7B%22family%22%3A%22Kring%22%2C%22given%22%3A%22David%20A%22%7D%5D%2C%22issued%22%3A%7B%22date-parts%22%3A%5B%5B%222017%22%2C7%5D%5D%7D%7D%7D%5D&quot; data-schema-version=&quot;9&quot;&gt;&lt;p&gt;&lt;span class=&quot;highlight&quot; data-annotation=&quot;%7B%22attachmentURI%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFFVSAPIC%22%2C%22annotationKey%22%3A%22FW4IRAVU%22%2C%22color%22%3A%22%23ff6666%22%2C%22pageLabel%22%3A%22103%22%2C%22position%22%3A%7B%22pageIndex%22%3A113%2C%22rects%22%3A%5B%5B222.994%2C363.709%2C515.841%2C373.405%5D%2C%5B71.989%2C350.748%2C510.144%2C360.444%5D%2C%5B71.989%2C337.787%2C519.352%2C347.484%5D%2C%5B71.989%2C324.826%2C538.76%2C334.523%5D%2C%5B71.989%2C311.865%2C513.214%2C321.562%5D%2C%5B71.989%2C298.904%2C409.669%2C308.601%5D%5D%7D%2C%22citationItem%22%3A%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%22103%22%7D%7D&quot;&gt;“Collisions between planetesimals produced impact melt pools that differentiated (Goldstein et al., 2014; Worsham et al., 2017), allowing the denser metal and sulfide components to sink and, thus, collate into significant volumes. Based on the cooling rates of the iron meteorites, I estimate the craters were 150 to 300 km in diameter on planetesimals &amp;gt;300 km diameter. At some later date, the planetesimals were disrupted, producing iron metal-dominated asteroids, one of which eventually collided with Earth to produce Barringer Meteorite Crater.”&lt;/span&gt; &lt;/p&gt;
&lt;p&gt;&lt;span class=&quot;highlight&quot; data-annotation=&quot;%7B%22attachmentURI%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFFVSAPIC%22%2C%22annotationKey%22%3A%228L5RXPL9%22%2C%22color%22%3A%22%23ff6666%22%2C%22pageLabel%22%3A%22105%22%2C%22position%22%3A%7B%22pageIndex%22%3A115%2C%22rects%22%3A%5B%5B420.436%2C590.648%2C519.211%2C600.345%5D%2C%5B72.003%2C577.687%2C218.647%2C587.384%5D%5D%7D%2C%22citationItem%22%3A%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%22105%22%7D%7D&quot;&gt;“original asteroid had a mass of 100,000 to 200,000 tons.”&lt;/span&gt; &lt;span class=&quot;citation&quot; data-citation=&quot;%7B%22citationItems%22%3A%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%22105%22%7D%5D%2C%22properties%22%3A%7B%7D%7D&quot;&gt;(&lt;span class=&quot;citation-item&quot;&gt;Kring, 2017, p. 105&lt;/span&gt;)&lt;/span&gt;&lt;/p&gt;
&lt;/div&gt;</rdf:value>
    </bib:Memo>
    <bib:Memo rdf:about="#item_212">
        <rdf:value>&lt;div data-citation-items=&quot;%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22itemData%22%3A%7B%22id%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%2C%22type%22%3A%22article-journal%22%2C%22language%22%3A%22en%22%2C%22source%22%3A%22Zotero%22%2C%22title%22%3A%22Guidebook%20to%20the%20Geology%20of%20Barringer%20Meteorite%20Crater%2C%20Arizona%20(a%20k%20a%20Meteor%20Crater).%20Second%20edition%22%2C%22author%22%3A%5B%7B%22family%22%3A%22Kring%22%2C%22given%22%3A%22David%20A%22%7D%5D%2C%22issued%22%3A%7B%22date-parts%22%3A%5B%5B%222017%22%2C7%5D%5D%7D%7D%7D%5D&quot; data-schema-version=&quot;9&quot;&gt;&lt;p&gt;&lt;span class=&quot;highlight&quot; data-annotation=&quot;%7B%22attachmentURI%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFFVSAPIC%22%2C%22annotationKey%22%3A%22FEIM7MUW%22%2C%22color%22%3A%22%235fb236%22%2C%22pageLabel%22%3A%2235%22%2C%22position%22%3A%7B%22pageIndex%22%3A45%2C%22rects%22%3A%5B%5B108.104%2C364.669%2C512.4%2C374.365%5D%2C%5B71.981%2C351.708%2C231.763%2C361.404%5D%5D%7D%2C%22citationItem%22%3A%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%2235%22%7D%7D&quot;&gt;“complex breccia deposits that Shoemaker (1960) mapped as three units: authigenic breccia, allogenic breccia, and mixed debris.”&lt;/span&gt; &lt;span class=&quot;citation&quot; data-citation=&quot;%7B%22citationItems%22%3A%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%2235%22%7D%5D%2C%22properties%22%3A%7B%7D%7D&quot;&gt;(&lt;span class=&quot;citation-item&quot;&gt;Kring, 2017, p. 35&lt;/span&gt;)&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;authigenic- monomict, intraformational caused by disruptive shear, in faults&lt;/p&gt;
&lt;p&gt;allogenic- could be single or multiple formations, flowed down crater walls, shocked melted Coco and meteoritic debris &lt;/p&gt;
&lt;p&gt;mixed debris- contains all, fall out material blasted up then fell back down, &lt;/p&gt;
&lt;p&gt;&lt;/p&gt;
&lt;/div&gt;</rdf:value>
    </bib:Memo>
    <bib:Memo rdf:about="#item_374">
        <rdf:value>&lt;div data-citation-items=&quot;%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22itemData%22%3A%7B%22id%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%2C%22type%22%3A%22article-journal%22%2C%22citation-key%22%3A%22kringGuidebookGeologyBarringer2017%22%2C%22language%22%3A%22en%22%2C%22source%22%3A%22Zotero%22%2C%22title%22%3A%22Guidebook%20to%20the%20Geology%20of%20Barringer%20Meteorite%20Crater%2C%20Arizona%20(a%20k%20a%20Meteor%20Crater).%20Second%20edition%22%2C%22volume%22%3A%222040%22%2C%22author%22%3A%5B%7B%22family%22%3A%22Kring%22%2C%22given%22%3A%22David%20A%22%7D%5D%2C%22issued%22%3A%7B%22date-parts%22%3A%5B%5B%222017%22%2C7%5D%5D%7D%7D%7D%5D&quot; data-schema-version=&quot;9&quot;&gt;&lt;p&gt;&lt;span class=&quot;highlight&quot; data-annotation=&quot;%7B%22attachmentURI%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFFVSAPIC%22%2C%22annotationKey%22%3A%22GTM22ZS3%22%2C%22color%22%3A%22%23f19837%22%2C%22pageLabel%22%3A%2279%22%2C%22position%22%3A%7B%22pageIndex%22%3A89%2C%22rects%22%3A%5B%5B120.852%2C376.67%2C508.433%2C386.366%5D%2C%5B72%2C363.709%2C533.847%2C373.405%5D%2C%5B72%2C350.748%2C536.905%2C360.444%5D%2C%5B72%2C337.787%2C250.859%2C347.484%5D%5D%7D%2C%22citationItem%22%3A%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%2279%22%7D%7D&quot;&gt;“In structural terms, the overturned rim is a syncline with a circumferential axial trace or compound syncline, because there are actually two folds involved. The first is associated with the uplift and outward tilting of the beds in the crater walls (as described in the last chapter) and the second is with the complete overturning of those strata.”&lt;/span&gt; &lt;span class=&quot;citation&quot; data-citation=&quot;%7B%22citationItems%22%3A%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%2279%22%7D%5D%2C%22properties%22%3A%7B%7D%7D&quot;&gt;(&lt;span class=&quot;citation-item&quot;&gt;Kring, 2017, p. 79&lt;/span&gt;)&lt;/span&gt;&lt;/p&gt;
&lt;/div&gt;</rdf:value>
    </bib:Memo>
    <bib:Memo rdf:about="#item_253">
        <rdf:value>&lt;div data-citation-items=&quot;%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22itemData%22%3A%7B%22id%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%2C%22type%22%3A%22article-journal%22%2C%22citation-key%22%3A%22kringGuidebookGeologyBarringer2017%22%2C%22language%22%3A%22en%22%2C%22source%22%3A%22Zotero%22%2C%22title%22%3A%22Guidebook%20to%20the%20Geology%20of%20Barringer%20Meteorite%20Crater%2C%20Arizona%20(a%20k%20a%20Meteor%20Crater).%20Second%20edition%22%2C%22author%22%3A%5B%7B%22family%22%3A%22Kring%22%2C%22given%22%3A%22David%20A%22%7D%5D%2C%22issued%22%3A%7B%22date-parts%22%3A%5B%5B%222017%22%2C7%5D%5D%7D%7D%7D%5D&quot; data-schema-version=&quot;9&quot;&gt;&lt;p&gt;ROCK FLOUR&lt;/p&gt;
&lt;p&gt;&lt;span class=&quot;highlight&quot; data-annotation=&quot;%7B%22attachmentURI%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFFVSAPIC%22%2C%22pageLabel%22%3A%22106%22%2C%22position%22%3A%7B%22pageIndex%22%3A116%2C%22rects%22%3A%5B%5B94.56%2C305.53195312500003%2C536.19312%2C315.22848%5D%2C%5B72.00528%2C292.57099312500003%2C524.2699199999998%2C302.26752%5D%2C%5B72.00528%2C279.61003312500003%2C532.3953600000001%2C289.30656%5D%2C%5B72.00527999999997%2C266.64907312500003%2C528.2222399999997%2C276.3456%5D%2C%5B72.00527999999997%2C253.68811312500003%2C516.7296%2C263.38464%5D%2C%5B72.00527999999997%2C240.72715312500003%2C506.72736000000003%2C250.42368000000002%5D%2C%5B72.00527999999997%2C227.76619312500003%2C229.79999999999993%2C237.46272000000002%5D%5D%7D%2C%22citationItem%22%3A%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%22106%22%7D%7D&quot;&gt;“The fate of the missing material has been at the center of considerable debate. Barringer, of course, thought it was buried beneath the crater floor. He considered the alternative possibility that the object was vaporized (Barringer, 1910). In that case, he reasoned, the vaporized projectile and target materials would have re-condensed, producing a mass of material (perhaps similar to rock flour) that was stained with iron and nickel oxides. Since this is not observed, he argued the mass must still exist inside the crater. (At this point in the development of his model, he also thought the asteroid was a cluster of fragments rather than a solid mass.)”&lt;/span&gt; &lt;span class=&quot;citation&quot; data-citation=&quot;%7B%22citationItems%22%3A%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%22106%22%7D%5D%2C%22properties%22%3A%7B%7D%7D&quot;&gt;(&lt;span class=&quot;citation-item&quot;&gt;Kring, 2017, p. 106&lt;/span&gt;)&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span class=&quot;highlight&quot; data-annotation=&quot;%7B%22attachmentURI%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFFVSAPIC%22%2C%22pageLabel%22%3A%22223%22%2C%22position%22%3A%7B%22pageIndex%22%3A233%2C%22rects%22%3A%5B%5B120.84095999999997%2C442.67371312500006%2C509.6255999999999%2C452.37024%5D%2C%5B71.98895999999996%2C429.71275312500006%2C510.6744%2C439.40928%5D%2C%5B71.98895999999996%2C416.75179312500006%2C533.1407999999998%2C426.44832%5D%2C%5B71.98895999999996%2C403.79083312500006%2C528.6696%2C413.48736%5D%2C%5B71.9889599999999%2C390.82987312500006%2C514.2071999999998%2C400.5264%5D%2C%5B71.98895999999985%2C377.86891312500006%2C344.0587199999998%2C387.56544%5D%5D%7D%2C%22citationItem%22%3A%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%22223%22%7D%7D&quot;&gt;“At the top of the gap, just a few feet from the public trail, an incredibly white outcrop is visible (Fig. 19.2). The material in the outcrop is weakly consolidated. It is a mass of shocked and ejected sandstone that is transitional to a type of rock flour that was described by Barringer (1905). The material in the outcrop is heterogeneously damaged. Cores of surviving Coconino with traces of crossbedding can be found in it. Outcrops like this one also contain his Variety A shock-metamorphosed sandstone, which has a higher density than normal sandstone.”&lt;/span&gt; &lt;span class=&quot;citation&quot; data-citation=&quot;%7B%22citationItems%22%3A%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%22223%22%7D%5D%2C%22properties%22%3A%7B%7D%7D&quot;&gt;(&lt;span class=&quot;citation-item&quot;&gt;Kring, 2017, p. 223&lt;/span&gt;)&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span class=&quot;highlight&quot; data-annotation=&quot;%7B%22attachmentURI%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFFVSAPIC%22%2C%22pageLabel%22%3A%22230%22%2C%22position%22%3A%7B%22pageIndex%22%3A240%2C%22rects%22%3A%5B%5B177.59759999999986%2C111.08779312499995%2C510.34320000000014%2C120.78431999999995%5D%2C%5B71.96687999999989%2C98.12683312499995%2C527.4772799999997%2C107.82335999999995%5D%2C%5B71.96687999999989%2C85.16587312499995%2C264.73631999999986%2C94.86239999999995%5D%5D%7D%2C%22citationItem%22%3A%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%22230%22%7D%7D&quot;&gt;“Even farther to the west are the “Silica Pits,” which are composed of finely comminuted Coconino. At that location, fractured versions of the blocks at our feet occur in a massive and brilliantly white matrix of “rock flour.””&lt;/span&gt; &lt;span class=&quot;citation&quot; data-citation=&quot;%7B%22citationItems%22%3A%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%22230%22%7D%5D%2C%22properties%22%3A%7B%7D%7D&quot;&gt;(&lt;span class=&quot;citation-item&quot;&gt;Kring, 2017, p. 230&lt;/span&gt;)&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span class=&quot;highlight&quot; data-annotation=&quot;%7B%22attachmentURI%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFFVSAPIC%22%2C%22annotationKey%22%3A%22B65IMTSW%22%2C%22color%22%3A%22%235fb236%22%2C%22pageLabel%22%3A%2253%22%2C%22position%22%3A%7B%22pageIndex%22%3A63%2C%22rects%22%3A%5B%5B457.947%2C285.943%2C517.961%2C295.64%5D%2C%5B71.967%2C272.982%2C537.457%2C282.679%5D%2C%5B71.967%2C260.021%2C283.107%2C269.718%5D%5D%7D%2C%22citationItem%22%3A%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%2253%22%7D%7D&quot;&gt;“a quantitative microscopic study of the rock flour and the relative proportions of different types of silica components in it has not been done to evaluate this suggestion.”&lt;/span&gt; &lt;span class=&quot;citation&quot; data-citation=&quot;%7B%22citationItems%22%3A%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%2253%22%7D%5D%2C%22properties%22%3A%7B%7D%7D&quot;&gt;(&lt;span class=&quot;citation-item&quot;&gt;Kring, 2017, p. 53&lt;/span&gt;)&lt;/span&gt;&lt;/p&gt;
&lt;/div&gt;</rdf:value>
    </bib:Memo>
    <bib:Memo rdf:about="#item_92">
        <rdf:value>&lt;div data-citation-items=&quot;%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22itemData%22%3A%7B%22id%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%2C%22type%22%3A%22article-journal%22%2C%22language%22%3A%22en%22%2C%22source%22%3A%22Zotero%22%2C%22title%22%3A%22Guidebook%20to%20the%20Geology%20of%20Barringer%20Meteorite%20Crater%2C%20Arizona%20(a%20k%20a%20Meteor%20Crater).%20Second%20edition%22%2C%22author%22%3A%5B%7B%22family%22%3A%22Kring%22%2C%22given%22%3A%22David%20A%22%7D%5D%2C%22issued%22%3A%7B%22date-parts%22%3A%5B%5B%222017%22%2C7%5D%5D%7D%7D%7D%5D&quot; data-schema-version=&quot;9&quot;&gt;&lt;p&gt;Sediment is ~1,070 m thick, overlie basement&lt;/p&gt;
&lt;p&gt;Coconino SS, Toroweap FM, Kaibab FM, and Moenkopi FM&lt;/p&gt;
&lt;p&gt;&lt;span class=&quot;highlight&quot; data-annotation=&quot;%7B%22attachmentURI%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFFVSAPIC%22%2C%22annotationKey%22%3A%22KSMUSRFJ%22%2C%22color%22%3A%22%23a28ae5%22%2C%22pageLabel%22%3A%227%22%2C%22position%22%3A%7B%22pageIndex%22%3A17%2C%22rects%22%3A%5B%5B89.979%2C436.625%2C183.587%2C446.321%5D%5D%7D%2C%22citationItem%22%3A%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%227%22%7D%7D&quot;&gt;“Coconino Sandstone.”&lt;/span&gt; white, fine grained, saccharoidal quartzose sandstone of massive beds of cross bedding. 210-240 m thick&lt;/p&gt;
&lt;p&gt;&lt;/p&gt;
&lt;p&gt;&lt;span class=&quot;highlight&quot; data-annotation=&quot;%7B%22attachmentURI%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFFVSAPIC%22%2C%22annotationKey%22%3A%22J9PILI4P%22%2C%22color%22%3A%22%232ea8e5%22%2C%22pageLabel%22%3A%227%22%2C%22position%22%3A%7B%22pageIndex%22%3A17%2C%22rects%22%3A%5B%5B192.342%2C436.625%2C478.631%2C446.321%5D%5D%7D%2C%22citationItem%22%3A%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%227%22%7D%7D&quot;&gt;“The Coconino Sandstone is white, fine-grained, and saccharoidal”&lt;/span&gt; &lt;span class=&quot;citation&quot; data-citation=&quot;%7B%22citationItems%22%3A%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%227%22%7D%5D%2C%22properties%22%3A%7B%7D%7D&quot;&gt;(&lt;span class=&quot;citation-item&quot;&gt;Kring, 2017, p. 7&lt;/span&gt;)&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span class=&quot;highlight&quot; data-annotation=&quot;%7B%22attachmentURI%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFFVSAPIC%22%2C%22annotationKey%22%3A%22DNV4CKAA%22%2C%22color%22%3A%22%232ea8e5%22%2C%22pageLabel%22%3A%227%22%2C%22position%22%3A%7B%22pageIndex%22%3A17%2C%22rects%22%3A%5B%5B239.538%2C423.907%2C473.21%2C433.603%5D%2C%5B71.973%2C411.31%2C156.716%2C421.007%5D%5D%7D%2C%22citationItem%22%3A%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%227%22%7D%7D&quot;&gt;“quartzose sandstone that occurs in massive beds with cross-stratification.”&lt;/span&gt; &lt;span class=&quot;citation&quot; data-citation=&quot;%7B%22citationItems%22%3A%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%227%22%7D%5D%2C%22properties%22%3A%7B%7D%7D&quot;&gt;(&lt;span class=&quot;citation-item&quot;&gt;Kring, 2017, p. 7&lt;/span&gt;)&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span class=&quot;highlight&quot; data-annotation=&quot;%7B%22attachmentURI%22%3A%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFFVSAPIC%22%2C%22annotationKey%22%3A%228U2C2JRW%22%2C%22color%22%3A%22%23ff6666%22%2C%22pageLabel%22%3A%22112%22%2C%22position%22%3A%7B%22pageIndex%22%3A122%2C%22rects%22%3A%5B%5B345.594%2C304.323%2C505.82%2C313.071%5D%2C%5B72.59%2C292.56%2C524.465%2C301.308%5D%2C%5B72.59%2C280.797%2C481.408%2C289.545%5D%2C%5B72.59%2C269.035%2C501.428%2C277.783%5D%2C%5B72.59%2C257.272%2C264.788%2C266.02%5D%5D%7D%2C%22citationItem%22%3A%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%22112%22%7D%7D&quot;&gt;“Furthermore, lightly-shocked meteorites appear to come from a shallower depth (mean of 0.8 m) than moderately- to heavily-shocked meteorites (mean of 1.3 m depth). The lightly-shocked meteorites are distributed on the plain surrounding the crater, while moderately- to heavily-shocked meteorites are concentrated near the crater rim. Almost all of the diamondbearing specimens were found on the crater rim.”&lt;/span&gt; &lt;span class=&quot;citation&quot; data-citation=&quot;%7B%22citationItems%22%3A%5B%7B%22uris%22%3A%5B%22http%3A%2F%2Fzotero.org%2Fusers%2Flocal%2FOLWMPY2p%2Fitems%2FFQK5G7KA%22%5D%2C%22locator%22%3A%22112%22%7D%5D%2C%22properties%22%3A%7B%7D%7D&quot;&gt;(&lt;span class=&quot;citation-item&quot;&gt;Kring, 2017, p. 112&lt;/span&gt;)&lt;/span&gt;&lt;/p&gt;
&lt;/div&gt;</rdf:value>
    </bib:Memo>

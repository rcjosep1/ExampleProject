@article{renikNewHypothesisAmount2013,
  title = {A New Hypothesis for the Amount and Distribution of Dextral Displacement along the {{Fish Lake Valley}}–Northern {{Death Valley}}–{{Furnace Creek}} Fault Zone, {{California}}‐{{Nevada}}},
  author = {Renik, Byrdie and Christie‐Blick, Nicholas},
  date = {2013-03},
  journaltitle = {Tectonics},
  volume = {32},
  number = {2},
  pages = {123--145},
  issn = {0278-7407, 1944-9194},
  doi = {10.1029/2012TC003170},
  url = {https://agupubs.onlinelibrary.wiley.com/doi/10.1029/2012TC003170},
  urldate = {2026-03-02},
  abstract = {Abstract             The Fish Lake Valley–northern Death Valley–Furnace Creek fault zone, a \textasciitilde 250 km long, predominantly right‐lateral structure in California and Nevada, is a key element in tectonic reconstructions of the Death Valley area, Eastern California Shear Zone and Walker Lane, and central Basin and Range Province. Total displacement on the fault zone is contested, however, with estimates ranging from \textasciitilde 30 to \textasciitilde 63 km or more. Here we present a new synthesis of available constraints. Preextensional thrust faults, folds, and igneous rocks indicate that offset reaches a maximum of \textasciitilde 50 km. Neogene rocks constrain its partitioning over time. Most offset is interpreted as ≤ \textasciitilde 13–10 Ma, accruing at \textasciitilde 3–5 mm/yr in the middle of the fault zone and more slowly toward the tips. The offset markers imply \textasciitilde 68 ± 14 km of translation between the Cottonwood Mountains and Resting Spring–Nopah Range (\textasciitilde 60 ± 14 km since \textasciitilde 15 Ma) through a combination of strike slip and crustal extension. This suggests that a previous interpretation of \textasciitilde 104 ± 7 km, based on the middle Miocene Eagle Mountain Formation, is an overestimate by \textasciitilde 50\%. Our results also help to mitigate a discrepancy in the \textasciitilde 12–0 Ma strain budget for the Eastern California Shear Zone. Displacement has previously been estimated at \textasciitilde 100 ± 10 km and \textasciitilde 67 ± 6 km for the Basin and Range and Mojave portions of the shear zone, respectively. Our new estimate of \textasciitilde 74 ± 17 km for the Basin and Range is within the uncertainty of the Mojave estimate.           ,              Key Points                                                                Furnace Creek fault zone accommodated \&lt; \textasciitilde 50 km of dextral offset since \textasciitilde 13 Ma                                                     Combined extension and strike slip in central Death Valley overestimated by \textasciitilde 50\%                                                     Results resolve a \textasciitilde 12‐0 Ma strain discrepancy for Eastern California Shear Zone},
  langid = {english}
}

